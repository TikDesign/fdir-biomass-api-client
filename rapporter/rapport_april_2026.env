# ════════════════════════════════════════════════════════
# rapport_april_2026.env – Biomasserapportering April 2026
# Fyll inn alle verdier og lagre filen.
# Send filen til Tor Ivan når den er ferdig utfylt.
# ════════════════════════════════════════════════════════

# ── Rapporteringsperiode ─────────────────────────────────
# Året rapporten gjelder for (4 siffer)
RAPPORTERINGS_AAR=2026

# Måneden rapporten gjelder for (2 siffer)
# 01=Januar, 02=Februar, 03=Mars ... 12=Desember
RAPPORTERINGS_MAANED=04

# ── Merder som skal rapporteres ──────────────────────────
# Liste over merd-ID-er, kommaseparert
MERDER=M2,M3,M4,M5,M7

# ── Merddata ─────────────────────────────────────────────
# Fiskegruppenummer = nummeret til fiskegruppen merden tilhører
# Volum             = merdvolum i kubikkmeter (m³) – endres sjelden
# Årsklasse         = årstallet fisken ble klekket (4 siffer)
# Beholdning        = antall fisk i merden ved månedsslutt
# Snittvekt         = gjennomsnittsvekt i gram
# Fôrforbruk        = fôrforbruk i kilo denne måneden
# Død               = antall døde fisk denne måneden
# Destruerte        = antall kasserte/destruerte fisk denne måneden
# Kraknes           = antall fisk flyttet til Kraknes denne måneden

# Merd M2
M2_FISKEGRUPPENUMMER=2023.01.02.01
M2_VOLUM=300
M2_AARSKLASSE=2023
M2_BEHOLDNING=552
M2_SNITTVEKT=4089
M2_FORFORBRUK=170
M2_DOED=2
M2_DESTRUERTE=2
M2_KRAKNES=0

